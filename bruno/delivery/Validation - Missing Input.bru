meta {
  name: Validation - Missing Input
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/delivery
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {}
}

assert {
  res.status: eq 400
  res.body.error: isDefined
}

tests {
  test("should return 400 when input is missing", function() {
    expect(res.getBody().error).to.be.a("string");
  });
}
